# Marsh local/runtime configuration.
# Values here are intentionally blank. Inject real secrets with your secret
# manager or CI environment; never commit populated .env files.

DAYTONA_API_KEY=
DAYTONA_API_BASE=https://app.daytona.io/api
DAYTONA_TARGET=us

GH_APP_ID=
GH_APP_INSTALLATION_ID=
GH_APP_KEY_PATH=

GHCR_USER=
GHCR_TOKEN=
GHCR_REGISTRY_NAME=ghcr-marsh
GHCR_IMAGE_OWNER=
GHCR_IMAGE_NAME=marsh-runner
MARSH_RUNNER_DOCKERFILE=runner-image/Dockerfile

MARSH_RUNNER_CONFIG=/etc/marsh/runners.toml
MARSH_DEFAULT_SNAPSHOT=marsh-runner-default
MARSH_LARGE_SNAPSHOT=marsh-runner-large
